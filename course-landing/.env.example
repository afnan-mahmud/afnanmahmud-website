# =============================================================================
# course.afnanmahmud.com — required environment variables
# =============================================================================
# This subdomain app shares the main app's database and gateway. In production
# these must be present in THIS process's environment (the standalone server does
# NOT auto-load repo-root .env files — see README "Runtime env in production").
#
# Copy to .env.local (local dev) or inject via pm2 `env` / `--env-file` on the VPS.
# Only the variables this app actually reads are listed here.
# -----------------------------------------------------------------------------

# --- Runtime mode ---
# development = payment dev-bypass ON (enroll succeeds WITHOUT paying — dev only).
# In production set NODE_ENV=production so EPS verification is enforced.
NODE_ENV=development

# --- Base URL (REQUIRED, subdomain-specific) ---
# Used ONLY to build the EPS success/fail/cancel redirect targets, so the whole
# payment round-trip stays on this subdomain. No NextAuth runs here.
# Local: http://localhost:3001   Production: https://course.afnanmahmud.com
NEXTAUTH_URL=http://localhost:3001

# --- Database (REQUIRED) ---
# Same MongoDB as the main app — a purchase here unlocks on afnanmahmud.com login.
MONGODB_URI=

# --- EPS Payment Gateway (REQUIRED for real payments) ---
# Same merchant credentials as the main app. If these are unset AND
# NODE_ENV!=production, the enroll route dev-bypasses the gateway.
EPS_USERNAME=
EPS_PASSWORD=
EPS_HASH_KEY=
EPS_MERCHANT_ID=
EPS_STORE_ID=
# Host root only (client appends /v1/...). Sandbox: https://sandbox.eps.com.bd  Prod: https://pgapi.eps.com.bd
EPS_BASE_URL=https://sandbox.eps.com.bd
# Transaction type: 1=Web, 2=Android, 3=iOS (default 1)
EPS_TRANSACTION_TYPE_ID=1

# --- Meta Pixel + Conversions API (optional — all tracking is a no-op if unset) ---
# NEXT_PUBLIC_* is inlined at BUILD time → rebuild after changing it.
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# --- TikTok Pixel + Events API (optional — no-op if unset) ---
# The base pixel is mounted in app/layout.tsx; without this id the client
# trackTikTok() calls in EnrollModal / payment success silently do nothing.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
TIKTOK_EVENTS_ACCESS_TOKEN=
TIKTOK_TEST_EVENT_CODE=

# --- Google Tag Manager (optional — no-op if unset) ---
# Same container as the main app; GTM only receives page_view here.
NEXT_PUBLIC_GTM_ID=

# --- Microsoft Clarity (optional — no-op if unset) ---
# Same project as the main app. Every route on this subdomain is public, so
# nothing is excluded (the /admin, /dashboard exclusions don't exist here).
NEXT_PUBLIC_CLARITY_ID=

# -----------------------------------------------------------------------------
# NOT needed by this app (main app only): NEXTAUTH_SECRET, AUTH_TRUST_HOST,
# BULKSMS_*, WHATSAPP_*, VDOCIPHER_API_SECRET, CLOUDINARY_*, RESEND_API_KEY,
# RECONCILE_SECRET (reconcile cron runs on the main app).
# -----------------------------------------------------------------------------
