# Afnan Mahmud — Environment Variables
# Copy this file to .env.local and fill in your values.
#
# PRODUCTION (Hostinger VPS): do NOT ship this dev file. On the server set:
#   NODE_ENV=production            (enables EPS verification; disables payment dev-bypass)
#   NEXTAUTH_URL=https://yourdomain
#   AUTH_TRUST_HOST=true           (also hard-coded as trustHost in lib/auth.config.ts)
#   EPS_BASE_URL=https://pgapi.eps.com.bd   (live) + live EPS credentials
# Leaving NODE_ENV=development in production lets buyers enroll WITHOUT paying.
NODE_ENV=development

# MongoDB connection string (Atlas recommended over a local mongod on small VPS)
MONGODB_URI=

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Required when self-hosting behind a reverse proxy (set true in production):
AUTH_TRUST_HOST=true

# BulkSMSBD credentials
BULKSMS_API_KEY=
BULKSMS_SENDER_ID=

# WhatsApp Cloud API (Meta). Used for the webhook, the admin inbox, and login
# OTP delivery (via the `login_otp` authentication template — see
# scripts/submit-whatsapp-otp-template.ts). OTP falls back to SMS automatically.
# WHATSAPP_WEBHOOK_VERIFY_TOKEN: any random string you choose — paste the SAME
#   value into the App Dashboard → WhatsApp → Configuration → "Verify token".
#   Generate with: openssl rand -hex 16
# WHATSAPP_APP_SECRET: App Dashboard → Settings → Basic → "App Secret". Used to
#   verify Meta's X-Hub-Signature-256 on incoming webhook POSTs. In production
#   the webhook rejects unsigned/invalid requests; in dev it allows them.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# WHATSAPP_ACCESS_TOKEN: permanent/system-user token (App Dashboard → WhatsApp →
#   API Setup, or a System User token). Used to SEND replies + download inbound
#   media via the Graph API. Unset = admin inbox is read-only (no send).
# WHATSAPP_PHONE_NUMBER_ID: the WABA phone number id replies are sent from
#   (App Dashboard → WhatsApp → API Setup → "Phone number ID").
# WHATSAPP_BUSINESS_ACCOUNT_ID: the WABA id (App Dashboard → WhatsApp → API
#   Setup → "WhatsApp Business Account ID"). Needed only to submit/check the
#   login OTP authentication template via scripts/submit-whatsapp-otp-template.ts.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# NEXT_PUBLIC_WHATSAPP_NUMBER: business number in wa.me form (digits only, e.g.
#   8801XXXXXXXXX). Powers the floating WhatsApp button on the landing page.
NEXT_PUBLIC_WHATSAPP_NUMBER=
# NEXT_PUBLIC_WHATSAPP_OTP_ENABLED: master switch for login OTP over WhatsApp.
#   Leave 'false' (or unset) = login OTP is SIM/SMS only (safe default). Set to
#   'true' ONLY after the `login_otp` authentication template is APPROVED in Meta
#   (check: node --env-file=.env.local --env-file=.env scripts/submit-whatsapp-otp-template.ts --status).
#   Read by both the API route and the OTP page, so one flip switches everything.
#   It is a NEXT_PUBLIC_ var (build-time inlined) — rebuild after changing it.
NEXT_PUBLIC_WHATSAPP_OTP_ENABLED=false
# WHATSAPP_ABANDONED_ENABLED: master switch for the abandoned-enrollment WhatsApp
#   follow-up sweep (server-only). Leave 'false' until the `enroll_followup`
#   UTILITY template is APPROVED in Meta (submit/check with
#   scripts/submit-whatsapp-followup-template.ts). The sweep runs via the
#   afnan-abandoned-whatsapp PM2 cron and reuses RECONCILE_SECRET for auth.
WHATSAPP_ABANDONED_ENABLED=false

# EPS Payment Gateway (Easy Payment System — V5 merchant API)
EPS_USERNAME=
EPS_PASSWORD=
EPS_HASH_KEY=
EPS_MERCHANT_ID=
EPS_STORE_ID=
# Host root only; the client appends /v1/... paths. Sandbox: https://sandbox.eps.com.bd  Prod: https://pgapi.eps.com.bd
EPS_BASE_URL=https://sandbox.eps.com.bd
# Transaction type: 1=Web, 2=Android, 3=iOS (default 1)
EPS_TRANSACTION_TYPE_ID=1
EPS_CANCEL_URL=http://localhost:3000/courses
# Shared secret for the payment reconciliation cron (recovers charged-but-not-
# finalized orders; EPS has no IPN). Generate with: openssl rand -hex 32
# Required for the PM2 `afnan-reconcile` cron to do anything.
RECONCILE_SECRET=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (optional — for email notifications)
RESEND_API_KEY=

# VdoCipher (secure DRM video playback). Server-side API secret from the
# VdoCipher dashboard (Settings → API). Lesson "videoId" fields store VdoCipher
# Video IDs. When unset, the player shows a "not configured" state (no crash).
VDOCIPHER_API_SECRET=

# Meta Pixel + Conversions API
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# TikTok Pixel + Events API. Unset = disabled (all TikTok tracking is a no-op).
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
TIKTOK_EVENTS_ACCESS_TOKEN=
TIKTOK_TEST_EVENT_CODE=

# Google Tag Manager container id (GTM-XXXXXXX). Unset = GTM disabled (no-op).
NEXT_PUBLIC_GTM_ID=

# Microsoft Clarity (public-facing analytics; never loads on /admin or /dashboard).
# Project id from clarity.microsoft.com. Leave blank to disable.
NEXT_PUBLIC_CLARITY_ID=
